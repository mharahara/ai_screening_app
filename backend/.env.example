# LLM provider 選択（ollama | claude）。未設定なら ollama（ローカル完結）。
LLM_PROVIDER=ollama

# Ollama 連携（LLM_PROVIDER=ollama のとき）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT=120

# Claude 連携（LLM_PROVIDER=claude のとき）。ANTHROPIC_API_KEY は必須。
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=4096

# 構造化・マッチングの LLM 呼び出しリトライ上限（初回 + リトライ）
PARSE_MAX_RETRIES=3

# データベース（SQLite）
DATABASE_URL=sqlite:///./rabbitpick.db
